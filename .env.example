# ============================================================
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit secrets.
# ============================================================

# ---- App environment ----
# "dev" | "prod"
APP_ENV=prod

# ---- LLM (override base.yaml) ----
# If Ollama runs on the host machine (outside Docker), use the host IP.
# Inside Docker Compose, the service name "ollama" is resolved automatically.
LLM__BASE_URL=http://ollama:11434/v1
LLM__MODEL=qwen2.5:14b
LLM__API_KEY=ollama
LLM__TEMPERATURE=0.0
LLM__USE_MOCK=false

# ---- Embedding ----
EMBEDDING__BASE_URL=http://ollama:11434/v1
EMBEDDING__MODEL=bge-m3

# ---- Postgres ----
POSTGRES_PASSWORD=change_me_in_production
POSTGRES__DSN=postgresql+psycopg://agent:change_me_in_production@postgres:5432/agentdb

# ---- Grafana ----
GRAFANA_PASSWORD=admin

# ---- Agent behaviour ----
AGENT_ALLOW_RESTART=0

# ---- Observability ----
OBS__LOG_LEVEL=INFO
OBS__LOG_FORMAT=json
